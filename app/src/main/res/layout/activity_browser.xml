<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- WebView - full screen -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Progress bar at top -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:progress="0"
        android:progressTint="#3B82F6" />

    <!-- Loading spinner overlay -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone" />

    <!-- Overlay Control Bar - shown on Menu/Enter press -->
    <LinearLayout
        android:id="@+id/overlayBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC0D1117"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- URL display -->
        <TextView
            android:id="@+id/urlDisplay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:singleLine="true"
            android:ellipsize="middle"
            android:paddingStart="8dp"
            android:paddingEnd="16dp" />

        <!-- Countdown timer -->
        <TextView
            android:id="@+id/refreshCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refresh in 60s"
            android:textColor="#3B82F6"
            android:textSize="13sp"
            android:paddingEnd="16dp" />

        <!-- Change URL button -->
        <ImageButton
            android:id="@+id/btnChangeUrl"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Change URL"
            android:layout_marginEnd="8dp" />

        <!-- Refresh button -->
        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Refresh"
            android:layout_marginEnd="8dp" />

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Settings" />

    </LinearLayout>

</FrameLayout>
