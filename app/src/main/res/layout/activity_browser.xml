<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- WebView - full screen -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Progress bar at top -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:progress="0"
        android:progressTint="#3B82F6" />

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone" />

    <!-- Floating Zoom Panel - always visible on right side -->
    <LinearLayout
        android:id="@+id/zoomPanel"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC0D1117"
        android:padding="4dp"
        android:elevation="10dp">

        <ImageButton
            android:id="@+id/btnFloatZoomIn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/arrow_up_float"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Zoom In"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/floatZoomLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <ImageButton
            android:id="@+id/btnFloatZoomOut"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/arrow_down_float"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Zoom Out" />

    </LinearLayout>

    <!-- Overlay Control Bar -->
    <LinearLayout
        android:id="@+id/overlayBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC0D1117"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- URL display -->
        <TextView
            android:id="@+id/urlDisplay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="middle"
            android:paddingStart="4dp"
            android:paddingEnd="8dp" />

        <!-- Countdown timer -->
        <TextView
            android:id="@+id/refreshCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refresh in 60s"
            android:textColor="#3B82F6"
            android:textSize="12sp"
            android:paddingEnd="12dp" />

        <!-- Zoom Out button -->
        <ImageButton
            android:id="@+id/btnZoomOut"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_zoom"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Zoom Out"
            android:layout_marginEnd="2dp" />

        <!-- Zoom level label -->
        <TextView
            android:id="@+id/zoomLevelText"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="100%"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginEnd="2dp" />

        <!-- Zoom In button -->
        <ImageButton
            android:id="@+id/btnZoomIn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_zoom"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Zoom In"
            android:layout_marginEnd="8dp" />

        <!-- Change URL button -->
        <ImageButton
            android:id="@+id/btnChangeUrl"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Change URL"
            android:layout_marginEnd="4dp" />

        <!-- Refresh button -->
        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Refresh"
            android:layout_marginEnd="4dp" />

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="@drawable/icon_button_bg"
            android:contentDescription="Settings" />

    </LinearLayout>

</FrameLayout>
