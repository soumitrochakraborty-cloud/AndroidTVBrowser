<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0D1117"
    android:padding="60dp">

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📺 TV Browser"
        android:textSize="36sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configure your browser settings"
        android:textSize="16sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="48dp" />

    <!-- Card Container -->
    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="32dp">

        <!-- URL Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Website URL"
            android:textSize="14sp"
            android:textColor="#8B949E"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="https://example.com"
            android:textColor="#FFFFFF"
            android:textColorHint="#555E6B"
            android:textSize="16sp"
            android:background="@drawable/input_background"
            android:padding="12dp"
            android:inputType="textUri"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:layout_marginBottom="28dp" />

        <!-- Refresh Interval -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto-Refresh Interval"
            android:textSize="14sp"
            android:textColor="#8B949E"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/refreshSpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="28dp" />

        <!-- Kiosk Mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kiosk / Full-Screen Mode"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hides system UI, blocks back button"
                    android:textSize="12sp"
                    android:textColor="#8B949E" />
            </LinearLayout>

            <Switch
                android:id="@+id/kioskSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Status text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F97316"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Start Button -->
        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Launch Browser"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/button_background"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
